MILOCO_PORT=1810
OPENCLAW_PORT=18789
OPENCLAW_INTERNAL_PORT=18790
OPENCLAW_BIND=auto
OPENCLAW_AUTH=token
OPENCLAW_CHAT_MAX_TOKENS=2048
OPENCLAW_CHAT_TIMEOUT_SECONDS=180
OPENCLAW_CHAT_CONTEXT_WINDOW=262144

# 默认使用 Docker Hub 镜像；国内 NAS 可把域名替换为 docker.1ms.run。
EASY_MILOCO_IMAGE=docker.io/andywu114/easy-miloco-nas:v0.5
EASY_MILOCO_BUILD=0
EASY_MILOCO_SKIP_PULL=0

# NAS 默认给局域网内其他设备访问。
# 18789 是公开入口，会自动跳转到带 token 的 OpenClaw 对话页。
# 18790 是容器内 OpenClaw 网关端口，不需要映射到 NAS。

# Miloco 后端在容器内监听所有网卡，配合 host 网络给局域网访问。
MILOCO_SERVER__HOST=0.0.0.0

# 模型配置。必须按你的服务商后台填写，不要把真实值提交到 git。
OMNI_MODEL=xiaomi/mimo-v2.5
OMNI_BASE_URL=
OMNI_API_KEY=

# OpenClaw 聊天模型配置。必须单独填写，不会复用 OMNI_*；provider 可留空自动推断。
OPENCLAW_CHAT_PROVIDER=
OPENCLAW_CHAT_MODEL=
OPENCLAW_CHAT_BASE_URL=
OPENCLAW_CHAT_API_KEY=

# 小米账号授权 payload。Agent 部署时由 Agent 获取并写入本机 .env。
MILOCO_ACCOUNT_AUTH=

# 默认自动选择 latest release 中的 NAS zip；x86_64 可临时回退 Windows 包里的 Linux payload。
# 如果你有内网镜像或手工上传的 NAS release zip，填 MILOCO_RELEASE_ZIP_URL。
MILOCO_RELEASE_API=https://api.github.com/repos/andy-JustSayWhen/easy-miloco/releases/latest
MILOCO_RELEASE_ZIP_URL=

# 高级用法：直接指定独立 install.sh。一般不需要。
MILOCO_INSTALL_URL=

# 1 = 下次启动强制重新跑安装流程；正常保持 0。
MILOCO_FORCE_INSTALL=0
